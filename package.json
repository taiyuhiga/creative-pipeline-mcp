{
  "name": "creative-pipeline-mcp",
  "version": "1.1.9-alpha.0",
  "private": false,
  "description": "QC-first MCP pipeline for Blender assets and Premiere media workflows.",
  "mcpName": "io.github.taiyuhiga/creative-pipeline-mcp",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taiyuhiga/creative-pipeline-mcp.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "packages/*/dist/**",
    "packages/*/src/**",
    "packages/*/package.json",
    "packages/premiere-cep-panel/CSXS",
    "packages/premiere-cep-panel/index.html",
    "packages/premiere-cep-panel/js",
    "packages/premiere-cep-panel/jsx",
    "packages/premiere-cep-panel/README.md",
    "docs",
    "examples",
    "scripts",
    "third_party_licenses",
    "server.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE",
    "SECURITY.md"
  ],
  "bin": {
    "creative-mcp-core": "packages/core/dist/server.js",
    "blender-pro-mcp": "packages/blender-pro-mcp/dist/server.js",
    "premiere-pro-mcp": "packages/premiere-pro-mcp/dist/server.js",
    "creative-pipeline-director": "packages/director-agent/dist/server.js",
    "creative-asset-sourcing": "packages/asset-sourcing/dist/server.js",
    "capcut-social-mcp": "packages/capcut-social-mcp/dist/server.js",
    "after-effects-mcp": "packages/after-effects-mcp/dist/server.js",
    "roblox-pro-mcp": "packages/roblox-pro-mcp/dist/server.js",
    "creative-mcp-dashboard": "packages/dashboard/dist/server.js"
  },
  "exports": {
    "./core": "./packages/core/dist/index.js",
    "./asset-sourcing": "./packages/asset-sourcing/dist/index.js",
    "./blender": "./packages/blender-pro-mcp/dist/index.js",
    "./premiere": "./packages/premiere-pro-mcp/dist/index.js",
    "./director": "./packages/director-agent/dist/index.js",
    "./capcut": "./packages/capcut-social-mcp/dist/index.js",
    "./after-effects": "./packages/after-effects-mcp/dist/index.js",
    "./roblox": "./packages/roblox-pro-mcp/dist/index.js",
    "./blender-gpl-adapters": "./packages/blender-gpl-adapters/dist/index.js",
    "./premiere-windows-adapter": "./packages/premiere-windows-adapter/dist/index.js"
  },
  "scripts": {
    "build": "tsc -b packages/core packages/asset-sourcing packages/blender-pro-mcp packages/premiere-pro-mcp packages/director-agent packages/capcut-social-mcp packages/after-effects-mcp packages/roblox-pro-mcp packages/blender-gpl-adapters packages/premiere-windows-adapter packages/dashboard",
    "clean": "tsc -b --clean packages/core packages/asset-sourcing packages/blender-pro-mcp packages/premiere-pro-mcp packages/director-agent packages/capcut-social-mcp packages/after-effects-mcp packages/roblox-pro-mcp packages/blender-gpl-adapters packages/premiere-windows-adapter packages/dashboard && rm -rf artifacts",
    "test": "npm run build && node --test tests/*.mjs",
    "prepack": "npm run build",
    "check:adapters": "node scripts/check-adapters.mjs",
    "check:schemas": "node scripts/check-tool-schemas.mjs",
    "check:v1-freeze": "node scripts/check-v1-freeze.mjs",
    "check:release": "node scripts/check-release-readiness.mjs",
    "simulate:providers": "node scripts/simulate-provider-workflows.mjs",
    "smoke:npm-install": "node scripts/npm-install-smoke.mjs",
    "release:assets": "node scripts/release-assets.mjs",
    "blender:bridge-worker": "node scripts/blender-bridge-worker.mjs",
    "simulate:premiere-cep": "node scripts/simulate-premiere-cep.mjs",
    "wait:premiere-e2e": "node scripts/wait-premiere-e2e-status.mjs",
    "package:premiere-cep": "node scripts/package-premiere-cep.mjs",
    "install:premiere-cep": "node scripts/install-premiere-cep.mjs",
    "uninstall:premiere-cep": "node scripts/install-premiere-cep.mjs --uninstall",
    "start:core": "node packages/core/dist/server.js",
    "start:asset-sourcing": "node packages/asset-sourcing/dist/server.js",
    "start:blender": "node packages/blender-pro-mcp/dist/server.js",
    "start:premiere": "node packages/premiere-pro-mcp/dist/server.js",
    "start:director": "node packages/director-agent/dist/server.js",
    "start:capcut": "node packages/capcut-social-mcp/dist/server.js",
    "start:after-effects": "node packages/after-effects-mcp/dist/server.js",
    "start:roblox": "node packages/roblox-pro-mcp/dist/server.js",
    "start:dashboard": "node packages/dashboard/dist/server.js"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.1",
    "@gltf-transform/cli": "4.3.0",
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
